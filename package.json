{
    "name": "release-action",
    "version": "1.21.0",
    "type": "module",
    "private": true,
    "description": "An action which manages a github release",
    "main": "lib/src/Main.js",
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf lib/*",
        "coverage": "jest --coverage",
        "format": "yarn biome format --write .",
        "package": "ncc build lib/src/Main.js --source-map --license licenses.txt",
        "test": "vitest run"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/step-security/release-action.git"
    },
    "keywords": [
        "actions",
        "node",
        "setup"
    ],
    "author": "step-security",
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "@actions/core": "^3.0.0",
        "@actions/github": "^9.0.0",
        "@types/node": "^25.1.0",
        "glob": "^13.0.6",
        "axios": "^1.15.2"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.4",
        "@octokit/plugin-rest-endpoint-methods": "^10.4.1",
        "@octokit/request-error": "^7.1.0",
        "@octokit/types": "^16.0.0",
        "@vercel/ncc": "^0.38.4",
        "@vitest/coverage-v8": "^4.1.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    }
}
